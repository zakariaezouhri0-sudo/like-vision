rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RÈGLES DE SÉCURITÉ OUVERTES POUR DÉVELOPPEMENT
    // Permet la lecture et l'écriture à tous les utilisateurs connectés ou non
    // ID de résolution : FULL_ACCESS_V2
    match /{document=**} {
      allow read, write: if true;
    }
  }
}